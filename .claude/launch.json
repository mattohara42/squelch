{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "squelch-static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const root='/Users/matt/Documents/Claude/Projects/squelch';const mime={'.html':'text/html','.js':'text/javascript','.css':'text/css','.json':'application/json'};http.createServer((req,res)=>{let p=path.normalize(path.join(root, decodeURIComponent(req.url.split('?')[0])));if(!p.startsWith(root)){res.writeHead(403);res.end();return;}if(p.endsWith(path.sep)) p=path.join(p,'index.html');fs.readFile(p,(err,data)=>{if(err){res.writeHead(404);res.end('Not found');return;}res.writeHead(200,{'Content-Type':mime[path.extname(p)]||'application/octet-stream'});res.end(data);});}).listen(8080);"],
      "port": 8080
    }
  ]
}
